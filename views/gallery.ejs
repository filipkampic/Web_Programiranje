<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Rock music photo gallery - dynamically generated with EJS and Express.">
    <!-- CSS putanje moraju biti apsolutne (s /) jer Express poslužuje iz public/ mape -->
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/gallery.css">
    <title>Gallery – Rock Music</title>
</head>

<body>
    <header>
        <h1>Gallery</h1>

        <label for="nav-toggle" class="hamburger" aria-label="Open navigation">☰</label>
        <input type="checkbox" id="nav-toggle" hidden>

        <ul class="nav-menu">
            <li><a href="/">Home</a></li>
            <li><a href="/graphs">Graphs</a></li>
            <li><a href="/gallery">Gallery</a></li>
        </ul>
    </header>

    <main>
        <!-- Galerija dinamički generirana EJS petljom -->
        <section class="gallery" aria-labelledby="gallery-heading">
            <% if (images.length === 0) { %>
                <p>No images.</p>
            <% } else { %>
                <% images.forEach(image => { %>
                    <!-- Svaka slika je figure s lightbox linkom -->
                    <figure class="gallery-image">
                        <a href="#<%= image.id %>" aria-label="Expand image: <%= image.title %>">
                            <img
                                src="<%= image.url %>"
                                alt="<%= image.alt %>"
                                loading="lazy">
                        </a>
                        <figcaption><%= image.title %></figcaption>
                    </figure>

                    <!-- Lightbox overlay za svaku sliku -->
                    <div id="<%= image.id %>" class="lightbox" role="dialog" aria-label="<%= image.title %>">
                        <a href="#" class="close" aria-label="Close">×</a>
                        <img src="<%= image.url %>" alt="<%= image.alt %>">
                    </div>
                <% }); %>
            <% } %>

        </section>
    </main>

    <footer>
        <p>&copy; 2026 Rock Music List. All rights reserved.</p>
    </footer>
</body>

</html>
